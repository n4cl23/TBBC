generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PublicationStatus {
  draft
  published
  archived
}

enum AssetStatus {
  planned
  modeling
  printing
  painting
  published
  archived
}

model WorldEntity {
  id          String            @id @default(cuid())
  type        String
  slug        String
  name        String
  data        Json
  status      PublicationStatus @default(draft)
  version     Int               @default(1)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  versions    EntityVersion[]
  outgoing    Relation[]        @relation("RelationFrom")
  incoming    Relation[]        @relation("RelationTo")
  mediaLinks  MediaRelation[]
  prompts     Prompt[]
  technical   TechnicalAsset[]
  productions ProductionProject[]
  translations ContentTranslation[]

  @@unique([type, slug])
  @@index([type, status])
}

model ContentTranslation {
  id          String            @id @default(cuid())
  entityId    String
  locale      String
  slug        String?
  fields      Json
  status      PublicationStatus @default(draft)
  version     Int               @default(1)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entity      WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, locale])
  @@index([locale, status])
}

model ProductionProject {
  id          String            @id @default(cuid())
  entityId    String
  status      String            @default("idea")
  owner       String?
  dueAt       DateTime?
  progress    Int               @default(0)
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entity      WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  stages      ProductionStage[]
  validations PrintValidation[]
  releases    Release[]

  @@index([status, dueAt])
  @@index([entityId])
}

model ProductionStage {
  id          String            @id @default(cuid())
  projectId   String
  key         String
  label       String
  order       Int
  status      String            @default("waiting")
  owner       String?
  dueAt       DateTime?
  notes       String?
  checklist   Json?
  files       Json?
  completedAt DateTime?
  project     ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, order])
}

model PrintValidation {
  id          String            @id @default(cuid())
  projectId   String
  stlAssetId  String?
  result      String            @default("pending")
  checklist   Json
  failures    Json?
  corrections Json?
  photos      Json?
  validatedBy String?
  validatedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, result])
}

model Release {
  id          String             @id @default(cuid())
  projectId   String
  name        String
  collection  String?
  status      String             @default("planned")
  plannedAt   DateTime?
  publishedAt DateTime?
  checklist   Json?
  assets      Json?
  downloads   Json?
  notes       String?
  channels    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     ProductionProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, plannedAt])
}

model Marketplace {
  id             String               @id @default(cuid())
  slug           String               @unique
  name           String
  logo           String?
  website        String
  description    String
  primaryColor   String
  secondaryColor String
  status         String               @default("active")
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  listings       MarketplaceListing[]
  translations   MarketplaceTranslation[]

  @@index([status])
}

model MarketplaceTranslation {
  id            String            @id @default(cuid())
  marketplaceId String
  locale        String
  name          String
  description   String
  seoTitle      String?
  seoDescription String?
  status        PublicationStatus @default(draft)
  version       Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  marketplace   Marketplace       @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([marketplaceId, locale])
  @@index([locale, status])
}

model MarketplaceListing {
  id            String             @id @default(cuid())
  slug          String             @unique
  entityId      String
  entityType    String
  marketplaceId String
  title         String
  url           String
  price         Decimal            @db.Decimal(12, 2)
  currency      String             @default("USD")
  status        String             @default("coming-soon")
  featured      Boolean            @default(false)
  releaseDate   DateTime?
  lastSync      DateTime?
  rating        Float?
  downloads     Int?
  license       String
  notes         String?
  badges        String[]
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  marketplace   Marketplace        @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  prices        MarketplacePrice[]

  @@unique([entityId, entityType, marketplaceId])
  @@index([entityType, entityId])
  @@index([marketplaceId, status])
  @@index([status, releaseDate])
}

model MarketplacePrice {
  id         String             @id @default(cuid())
  listingId  String
  amount     Decimal            @db.Decimal(12, 2)
  currency   String
  validFrom  DateTime           @default(now())
  validUntil DateTime?
  manual     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, validFrom])
}

model Relation {
  id            String      @id @default(cuid())
  fromId        String
  toId          String
  kind          String
  label         String?
  bidirectional Boolean     @default(true)
  metadata      Json?
  from          WorldEntity @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to            WorldEntity @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([fromId, toId, kind])
  @@index([fromId, kind])
  @@index([toId, kind])
}

model EntityVersion {
  id        String            @id @default(cuid())
  entityId  String
  version   Int
  data      Json
  status    PublicationStatus
  actor     String
  createdAt DateTime          @default(now())
  entity    WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, version])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  role       String?
  ip         String
  entityType String
  entityId   String
  operation  String
  changes    Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model MediaAsset {
  id        String          @id @default(cuid())
  slug      String          @unique
  filename  String
  src       String
  alt       String
  caption   String?
  author    String?
  license   String?
  category  String
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  version   Int             @default(1)
  tags      String[]
  metadata  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  relations MediaRelation[]
}

model MediaRelation {
  id       String      @id @default(cuid())
  mediaId  String
  entityId String
  role     String
  order    Int         @default(0)
  media    MediaAsset  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  entity   WorldEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entityId, role])
}

model Prompt {
  id        String       @id @default(cuid())
  entityId  String?
  tool      String
  title     String
  content   String
  version   Int          @default(1)
  tags      String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  entity    WorldEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([tool])
}

model TechnicalAsset {
  id           String       @id @default(cuid())
  entityId     String?
  name         String
  format       String
  src          String?
  scale        String?
  weightGrams  Float?
  printMinutes Int?
  resinMl      Float?
  volumeCm3    Float?
  status       AssetStatus  @default(planned)
  version      Int          @default(1)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entity       WorldEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([format, status])
}
