generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PublicationStatus {
  draft
  published
  archived
}

enum AssetStatus {
  planned
  modeling
  printing
  painting
  published
  archived
}

enum CanonStatus {
  draft
  review
  canonical
  retconned
  archived
}

enum CanonEntityKind {
  realm
  location
  faction
  character
  creature
  artifact
  event
  collection
}

enum SemanticImportance {
  contextual
  supporting
  major
  critical
}

model WorldEntity {
  id          String            @id @default(cuid())
  canonicalId String            @unique @default(uuid())
  type        String
  kind        CanonEntityKind?
  slug        String
  canonicalSlug String?
  name        String
  data        Json
  status      PublicationStatus @default(draft)
  canonStatus CanonStatus       @default(review)
  version     Int               @default(1)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  versions    EntityVersion[]
  outgoing    Relation[]        @relation("RelationFrom")
  incoming    Relation[]        @relation("RelationTo")
  mediaLinks  MediaRelation[]
  prompts     Prompt[]
  technical   TechnicalAsset[]
  productions ProductionProject[]
  translations ContentTranslation[]
  aliases     CanonAlias[]
  roles       EntityRole[]

  @@unique([type, slug])
  @@index([type, status])
  @@index([kind, canonStatus])
}

model CanonAlias {
  id            String          @id @default(cuid())
  entityId      String
  alias         String
  locale        String?
  reason        String
  createdAt     DateTime        @default(now())
  entity        WorldEntity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([alias, locale])
  @@index([entityId])
}

model EntityRole {
  id            String          @id @default(cuid())
  entityId      String
  role          String
  realmSlug     String?
  context       Json?
  status        CanonStatus     @default(review)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  entity        WorldEntity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, role, realmSlug])
  @@index([role, status])
}

model ContentTranslation {
  id          String            @id @default(cuid())
  entityId    String
  locale      String
  slug        String?
  fields      Json
  status      PublicationStatus @default(draft)
  version     Int               @default(1)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entity      WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, locale])
  @@index([locale, status])
}

model ProductionProject {
  id          String            @id @default(cuid())
  entityId    String
  status      String            @default("idea")
  owner       String?
  dueAt       DateTime?
  progress    Int               @default(0)
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entity      WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  stages      ProductionStage[]
  validations PrintValidation[]
  releases    Release[]

  @@index([status, dueAt])
  @@index([entityId])
}

model ProductionStage {
  id          String            @id @default(cuid())
  projectId   String
  key         String
  label       String
  order       Int
  status      String            @default("waiting")
  owner       String?
  dueAt       DateTime?
  notes       String?
  checklist   Json?
  files       Json?
  completedAt DateTime?
  project     ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, order])
}

model PrintValidation {
  id          String            @id @default(cuid())
  projectId   String
  stlAssetId  String?
  result      String            @default("pending")
  checklist   Json
  failures    Json?
  corrections Json?
  photos      Json?
  validatedBy String?
  validatedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     ProductionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, result])
}

model Release {
  id          String             @id @default(cuid())
  projectId   String
  name        String
  collection  String?
  status      String             @default("planned")
  plannedAt   DateTime?
  publishedAt DateTime?
  checklist   Json?
  assets      Json?
  downloads   Json?
  notes       String?
  channels    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     ProductionProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, plannedAt])
}

model Marketplace {
  id             String               @id @default(cuid())
  slug           String               @unique
  name           String
  logo           String?
  website        String
  description    String
  primaryColor   String
  secondaryColor String
  status         String               @default("active")
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  listings       MarketplaceListing[]
  translations   MarketplaceTranslation[]

  @@index([status])
}

model MarketplaceTranslation {
  id            String            @id @default(cuid())
  marketplaceId String
  locale        String
  name          String
  description   String
  seoTitle      String?
  seoDescription String?
  status        PublicationStatus @default(draft)
  version       Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  marketplace   Marketplace       @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@unique([marketplaceId, locale])
  @@index([locale, status])
}

model MarketplaceListing {
  id            String             @id @default(cuid())
  slug          String             @unique
  entityId      String
  entityType    String
  marketplaceId String
  title         String
  url           String
  price         Decimal            @db.Decimal(12, 2)
  currency      String             @default("USD")
  status        String             @default("coming-soon")
  featured      Boolean            @default(false)
  releaseDate   DateTime?
  lastSync      DateTime?
  rating        Float?
  downloads     Int?
  license       String
  notes         String?
  badges        String[]
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  marketplace   Marketplace        @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  prices        MarketplacePrice[]

  @@unique([entityId, entityType, marketplaceId])
  @@index([entityType, entityId])
  @@index([marketplaceId, status])
  @@index([status, releaseDate])
}

model MarketplacePrice {
  id         String             @id @default(cuid())
  listingId  String
  amount     Decimal            @db.Decimal(12, 2)
  currency   String
  validFrom  DateTime           @default(now())
  validUntil DateTime?
  manual     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, validFrom])
}

model Relation {
  id            String      @id @default(cuid())
  fromId        String
  toId          String
  kind          String
  label         String?
  bidirectional Boolean     @default(true)
  metadata      Json?
  from          WorldEntity @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to            WorldEntity @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([fromId, toId, kind])
  @@index([fromId, kind])
  @@index([toId, kind])
}

model EntityVersion {
  id        String            @id @default(cuid())
  entityId  String
  version   Int
  data      Json
  status    PublicationStatus
  actor     String
  createdAt DateTime          @default(now())
  entity    WorldEntity       @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, version])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  role       String?
  ip         String
  entityType String
  entityId   String
  operation  String
  changes    Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model SemanticRelation {
  id            String             @id @default(uuid()) @db.Uuid
  source        String             @db.Uuid
  target        String             @db.Uuid
  relationType  String
  weight        Float              @default(0.5)
  description   String
  status        CanonStatus        @default(review)
  timelineEvent String?            @db.Uuid
  startEra      String?
  endEra        String?
  importance    SemanticImportance @default(supporting)
  canonical     Boolean            @default(false)
  publicationStatus PublicationStatus @default(draft)
  aliases       String[]
  version       Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  versions      SemanticRelationVersion[]

  @@unique([source, target, relationType])
  @@index([source, relationType, status])
  @@index([target, relationType, status])
  @@index([timelineEvent])
  @@index([importance, canonical])
}

model SemanticRelationVersion {
  id         String             @id @default(uuid()) @db.Uuid
  relationId String             @db.Uuid
  version    Int
  data       Json
  status     PublicationStatus
  actor      String
  createdAt  DateTime           @default(now())
  relation   SemanticRelation   @relation(fields: [relationId], references: [id], onDelete: Cascade)

  @@unique([relationId, version])
  @@index([relationId, createdAt])
}

model MediaAsset {
  id        String          @id @default(cuid())
  slug      String          @unique
  filename  String
  src       String
  alt       String
  caption   String?
  author    String?
  license   String?
  category  String
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  version   Int             @default(1)
  tags      String[]
  metadata  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  relations MediaRelation[]
}

model MediaRelation {
  id       String      @id @default(cuid())
  mediaId  String
  entityId String
  role     String
  order    Int         @default(0)
  media    MediaAsset  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  entity   WorldEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entityId, role])
}

model Prompt {
  id        String       @id @default(cuid())
  entityId  String?
  tool      String
  title     String
  content   String
  version   Int          @default(1)
  tags      String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  entity    WorldEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([tool])
}

model TechnicalAsset {
  id           String       @id @default(cuid())
  entityId     String?
  name         String
  format       String
  src          String?
  scale        String?
  weightGrams  Float?
  printMinutes Int?
  resinMl      Float?
  volumeCm3    Float?
  status       AssetStatus  @default(planned)
  version      Int          @default(1)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entity       WorldEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([format, status])
}

model Creature {
  id                 String                @id @default(cuid())
  slug               String                @unique
  name               String
  epithet            String
  realmId            String
  category           String
  threatLevel        String
  summary            String
  lore               String
  origin             String
  behavior           String
  habitat            String
  diet               String
  weaknesses         String[]
  abilities          String[]
  visualDirection    String
  silhouette         String
  materials          String[]
  palette            String[]
  forbiddenElements  String[]
  guardianId         String?
  crownId            String?
  relatedCharacters  String[]
  relatedEvents      String[]
  relatedLocations   String[]
  status             String                @default("concept")
  editorialStatus    String                @default("draft")
  productionStatus   String                @default("concept")
  assetReadiness     String[]
  featured           Boolean               @default(false)
  image              String?
  heroImage          String?
  cardImage          String?
  thumbnail          String?
  gallery            Json?
  fallbackImage      String?
  usesPlaceholder    Boolean               @default(false)
  publicGlbUrl       String?
  publicGlbMimeType  String?
  publicGlbSizeBytes Int?
  publicGlbPublished Boolean               @default(false)
  scale              String?
  heightMm           Float?
  widthMm            Float?
  depthMm            Float?
  multipart          Boolean               @default(false)
  pieceCount         Int?
  baseIncluded       Boolean               @default(true)
  baseDiameter       Float?
  hollowRecommended  Boolean?
  drainHoles         Int?
  supportStatus      String                @default("unknown")
  lycheeReady         Boolean               @default(false)
  printStatus         String                @default("unverified")
  testedPrinter       String?
  testedResin         String?
  estimatedResinMl   Float?
  estimatedPrintTime Int?
  notes              String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  translations        CreatureTranslation[]
  assets              CreatureAsset[]
  habitats            CreatureHabitat[]

  @@index([realmId, category])
  @@index([threatLevel, status])
  @@index([featured, status])
}

model CreatureTranslation {
  id             String            @id @default(cuid())
  creatureId     String
  locale         String
  name           String
  epithet        String
  summary        String
  lore           String
  origin         String
  behavior       String
  habitat        String
  diet           String
  weaknesses     String[]
  abilities      String[]
  seoTitle       String
  seoDescription String
  imageAlt       String
  captions       String[]
  relationToRealm String
  historicalRecord String
  status         PublicationStatus @default(draft)
  version        Int               @default(1)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  creature       Creature          @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@unique([creatureId, locale])
  @@index([locale, status])
}

model CreatureAsset {
  id              String   @id @default(cuid())
  creatureId      String
  type            String
  filename        String
  url             String?
  localSourcePath String?
  mimeType        String
  sizeBytes       BigInt
  width           Int?
  height          Int?
  version         Int      @default(1)
  isPrimary       Boolean  @default(false)
  isPublic        Boolean  @default(false)
  checksum        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  creature        Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@unique([creatureId, checksum])
  @@index([creatureId, type, isPublic])
}

model CreatureHabitat {
  id         String   @id @default(cuid())
  creatureId String
  locationId String
  rarity     String
  population String
  season     String
  notes      String
  kind       String   @default("primary")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  creature   Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@unique([creatureId, locationId, kind])
  @@index([locationId, rarity])
}
