{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "tbbc-three.vercel.app" }],
      "destination": "https://theblackbanner.vercel.app/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "tbbc-three.vercel.app" }],
      "destination": "https://theblackbanner.vercel.app/:path*",
      "permanent": true
    }
  ]
}
