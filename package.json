{
  "name": "black-banner-chronicles",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "db:canon:dry-run": "tsx scripts/canon-db.ts dry-run",
    "db:canon:import": "tsx scripts/canon-db.ts apply",
    "db:canon:verify": "tsx scripts/canon-db.ts verify",
    "db:integrity": "tsx scripts/canon-db.ts verify",
    "smoke": "node scripts/smoke-test.mjs",
    "db:verify-isolation": "node scripts/verify-db-isolation.mjs",
    "bestiary:scan": "node scripts/import-bestiary-assets.ts",
    "bestiary:import": "node scripts/import-bestiary-assets.ts",
    "creatures:prepare-media": "node scripts/prepare-creature-media.ts",
    "creatures:validate-media": "node scripts/validate-creature-media.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "latest",
    "@types/three": "^0.185.1",
    "@vercel/blob": "^2.6.1",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "^0.35.3",
    "tailwindcss": "latest",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "tsx": "^4.23.1",
    "typescript": "latest",
    "vitest": "latest"
  }
}
